{
  "name": "vfkb-pi-package",
  "version": "0.1.0",
  "type": "module",
  "description": "ViloForge KnowledgeBase (vfkb) for the pi coding agent \u2014 per-project memory: session-start injection, per-turn delta, tool capture, brain-write gating, and the kb_* MCP tools.",
  "keywords": [
    "pi-package",
    "extension",
    "memory",
    "knowledge-base",
    "vfkb"
  ],
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/vilosource/vfkb-pi-package"
  },
  "pi": {
    "extensions": [
      "./bundles/vfkb-pi.mjs",
      "./bundles/vfkb-pi-bridge.mjs"
    ]
  },
  "engines": {
    "node": ">=20"
  },
  "peerDependencies": {
    "@mariozechner/pi-coding-agent": "*"
  },
  "peerDependenciesMeta": {
    "@mariozechner/pi-coding-agent": {
      "optional": true
    }
  },
  "scripts": {
    "test": "node --test test/",
    "gate": "node release-gate.mjs"
  }
}
